# Copy to .env and uncomment + fill values. Do not commit .env.

# ---------------------------------------------------------------------------
# Federation  (projects/federation/) — pytest + OpenAPI contract CLI
# ---------------------------------------------------------------------------
# DATACOMNS_FEDERATION_BASE_URL=https://federation-qa.ccdi.cancer.gov
# MEMGRAPH_URI=bolt://your-memgraph-host:7687
# MEMGRAPH_USER=memgraph
# MEMGRAPH_PASSWORD=
# FEDERATION_CONTRACT_REPORT_DIR=reports/federation/contract
# FEDERATION_CONTRACT_EXCLUDE_PATHS=/subject-mapping   # omit or set empty to test CPI route
# AL roster: defaults to seven QA source names in code when unset/blank. Override with CSV; use "none" or "-" to disable.
# FEDERATION_AL_EXPECTED_SOURCES=PCDC,Treehouse,StJude,KidsFirst,ccdi-ecDNA,ccdi-iusccc-pst,CCDI-DCC

# ---------------------------------------------------------------------------
# DCC  (projects/dcc/)
# ---------------------------------------------------------------------------
# DATACOMNS_DCC_BASE_URL=https://dcc-qa.ccdi.cancer.gov
# MEMGRAPH_DCC_URI=bolt://your-memgraph-host:7687
# MEMGRAPH_DCC_USER=memgraph
# MEMGRAPH_DCC_PASSWORD=

# ---------------------------------------------------------------------------
# Optional (any project)
# ---------------------------------------------------------------------------
# Printing is ON by default. Uncomment to turn OFF:
# DATACOMNS_PRINT_RESPONSES=0
# DATACOMNS_TEST_REPORT=0   # disable auto JSON/HTML under reports/
# DATACOMNS_REPORT_BODY_MAX_CHARS=50000000  # API/DB JSON in report (default 50M; lower if memory is tight)
# DATACOMNS_ENV=QA          # optional; shown on HTML report (else inferred from API URL host)
# DATACOMNS_SKIP_LIVE_TESTS=1
# DATACOMNS_SKIP_MEMGRAPH_TESTS=1
# DATACOMNS_SKIP_MEMGRAPH_DCC_TESTS=1
# DATACOMNS_HTTP_TIMEOUT=60
