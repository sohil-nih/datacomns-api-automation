# Copy to .env and uncomment + fill values. Do not commit .env.

# ---------------------------------------------------------------------------
# DCC  (projects/dcc/)
# ---------------------------------------------------------------------------
# DATACOMNS_FEDERATION_BASE_URL=https://dcc-qa.ccdi.cancer.gov
# MEMGRAPH_URI=bolt://your-memgraph-host:7687
# MEMGRAPH_USER=memgraph
# MEMGRAPH_PASSWORD=

# ---------------------------------------------------------------------------
# Optional (any project)
# ---------------------------------------------------------------------------
# Printing is ON by default. Uncomment to turn OFF:
# DATACOMNS_PRINT_RESPONSES=0
# DATACOMNS_TEST_REPORT=0   # disable auto JSON/HTML under reports/
# DATACOMNS_REPORT_BODY_MAX_CHARS=50000000  # API/DB JSON in report (default 50M; lower if memory is tight)
# DATACOMNS_ENV=QA          # optional; shown on HTML report (else inferred from API URL host)
# DATACOMNS_SKIP_LIVE_TESTS=1
# DATACOMNS_SKIP_MEMGRAPH_TESTS=1
# DATACOMNS_SKIP_MEMGRAPH_DCC_TESTS=1
# DATACOMNS_HTTP_TIMEOUT=60
